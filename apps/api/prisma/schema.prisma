generator client {
  provider        = "prisma-client-js"
  previewFeatures = []
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Impressora {
  A1
  H2C
}

enum Canal {
  SHOPEE
  ML
  SITE
  TIKTOK
}

enum VendedorShopeeTipo {
  CNPJ
  CPF_BAIXO
  CPF_ALTO
}

enum Origem {
  ML
  SHOPEE
  SITE
  ESTOQUE
}

enum JobStatus {
  FILA
  IMPRIMINDO
  CONCLUIDO
  EMBALADO
  ENVIADO
  CANCELADO
}

enum OrigemImagem {
  INSPIRACAO
  MODELO_3D
  GERADA
  OUTRA
}

enum CategoriaCusto {
  ALUGUEL
  ENERGIA
  INTERNET
  SOFTWARE
  ASSINATURA
  MARKETING
  INSUMOS
  IMPOSTOS
  OUTROS
}

enum SyncOrigem {
  MANUAL
  CRON
}

enum OportunidadeMarketplace {
  SHOPEE
  TIKTOK
  ML
  OUTRO
}

enum OportunidadeFonte {
  CONCORRENTE
  KEYWORD
  CATEGORIA
  TOP_VENDAS
  // Ideia autoral da Mahou inspirada em produtos do marketplace.
  // externalId é um cuid local (não Shopee item). Notas guardam inspirações + análise.
  IDEIA_GERADA
}

enum OportunidadeStatus {
  NOVO
  EM_ANALISE
  APROVADO
  DESCARTADO
  VIRARAM_PRODUTO
}

model Usuario {
  id        String   @id @default(cuid())
  email     String   @unique
  senhaHash String
  criadoEm  DateTime @default(now())
}

model Filamento {
  id              String    @id @default(cuid())
  nome            String    @unique
  custoKgCentavos Int
  potenciaA1W     Int
  potenciaH2cW    Int
  observacao      String?
  ativo           Boolean   @default(true)
  produtos        Produto[]
  criadoEm        DateTime  @default(now())
  atualizadoEm    DateTime  @updatedAt
}

model Produto {
  id                String                @id @default(cuid())
  nome              String
  inspiracao        String?
  modelo3dUrl       String?
  larguraCm         Decimal?              @db.Decimal(6, 1)
  alturaCm          Decimal?              @db.Decimal(6, 1)
  profundidadeCm    Decimal?              @db.Decimal(6, 1)
  filamentoId       String
  filamento         Filamento             @relation(fields: [filamentoId], references: [id])
  pesoG             Decimal               @db.Decimal(10, 2)
  tempoH            Decimal               @db.Decimal(10, 2)
  impressora        Impressora
  embalagemCentavos Int
  precoCentavos     Int
  canalPrincipal    Canal
  ativo             Boolean               @default(true)
  /// Indica se o produto já foi publicado no marketplace.
  /// Fluxo externo de geração de imagem só processa produtos com anunciado=false.
  anunciado         Boolean               @default(false)
  /// Produto incompleto (criado a partir de Oportunidade sem preencher tudo).
  /// Quando true: alguns campos podem estar zerados (peso/tempo) e ativo=false.
  /// Usuário precisa completar antes de anunciar.
  rascunho          Boolean               @default(false)
  jobs              JobProducao[]
  vendas            Venda[]
  insumos           ProdutoInsumo[]
  imagens           ProdutoImagem[]
  oportunidades     ProdutoOportunidade[]
  criadoEm          DateTime              @default(now())
  atualizadoEm      DateTime              @updatedAt
}

/// Insumo reutilizável usado em vários produtos (caixa, fita, etiqueta).
/// Soft-delete via ativo=false — produtos antigos referenciam insumos antigos.
model Insumo {
  id                    String          @id @default(cuid())
  nome                  String          @unique
  unidade               String // texto livre: "un", "m", "kg", "ml"
  custoUnitarioCentavos Int
  observacao            String?
  ativo                 Boolean         @default(true)
  produtos              ProdutoInsumo[]
  criadoEm              DateTime        @default(now())
  atualizadoEm          DateTime        @updatedAt
}

/// Pivot Produto↔Insumo com quantidade consumida por unidade de produto.
/// qtd em Decimal(10,3) cobre frações: 0.5m de fita, 0.125kg de papel etc.
model ProdutoInsumo {
  id        String  @id @default(cuid())
  produtoId String
  produto   Produto @relation(fields: [produtoId], references: [id], onDelete: Cascade)
  insumoId  String
  insumo    Insumo  @relation(fields: [insumoId], references: [id])
  qtd       Decimal @db.Decimal(10, 3)

  @@unique([produtoId, insumoId])
}

/// Imagem de referência do produto (inspiração, modelo 3D, foto manual ou gerada).
/// `arquivo` é path relativo a STORAGE_DIR: "<produtoId>/<imagemId>.jpg".
/// Sharp normaliza tudo pra JPG max 2000px na hora do upload — original não fica.
model ProdutoImagem {
  id        String       @id @default(cuid())
  produtoId String
  produto   Produto      @relation(fields: [produtoId], references: [id], onDelete: Cascade)
  arquivo   String
  origem    OrigemImagem @default(OUTRA)
  ordem     Int          @default(0)
  larguraPx Int?
  alturaPx  Int?
  bytes     Int?
  criadoEm  DateTime     @default(now())

  @@index([produtoId])
}

model Venda {
  id                    String   @id @default(cuid())
  produtoId             String
  produto               Produto  @relation(fields: [produtoId], references: [id])
  qtd                   Int
  precoUnitarioCentavos Int // pode diferir de Produto.precoCentavos
  canal                 Canal
  dataVenda             DateTime
  observacao            String?
  criadoEm              DateTime @default(now())

  @@index([dataVenda])
  @@index([canal])
}

/// Custo geral da Mahou Prints (aluguel, internet, software, etc).
/// `dataCompetencia` é sempre dia 1 do mês — agrupa por mês competência.
/// `recorrente=true` gera 12 cópias futuras na criação (com geradoAutomatico=true).
model Custo {
  id               String         @id @default(cuid())
  descricao        String
  categoria        CategoriaCusto
  valorCentavos    Int
  dataCompetencia  DateTime
  recorrente       Boolean        @default(false)
  geradoAutomatico Boolean        @default(false)
  observacao       String?
  criadoEm         DateTime       @default(now())

  @@index([dataCompetencia])
  @@index([categoria])
}

/// Singleton: sempre id=1. Configurações globais do Hub.
model Parametro {
  id                          Int                @id @default(1)
  tarifaKwhCentavos           Int
  vendedorShopee              VendedorShopeeTipo
  emCampanhaShopee            Boolean            @default(false)
  adicionalCampanhaPct        Decimal            @db.Decimal(5, 2)
  comissaoMlPct               Decimal            @db.Decimal(5, 2)
  impostoAtivo                Boolean            @default(false)
  impostoPct                  Decimal            @db.Decimal(5, 2)
  // Taxas do TikTok Shop são percentuais simples (sem faixa por preço).
  // Defaults batem com a estrutura padrão (jul/2026): comissão+SFP+afiliado+pagamento.
  tiktokComissaoPlataformaPct Decimal            @default(6.00) @db.Decimal(5, 2)
  tiktokTaxaSfpPct            Decimal            @default(6.00) @db.Decimal(5, 2)
  tiktokComissaoAfiliadoPct   Decimal            @default(30.00) @db.Decimal(5, 2)
  tiktokTaxaPagamentoPct      Decimal            @default(3.00) @db.Decimal(5, 2)
  margemThresholdVerde        Decimal            @default(0.30) @db.Decimal(4, 3)
  margemThresholdAmarelo      Decimal            @default(0.15) @db.Decimal(4, 3)
  atualizadoEm                DateTime           @updatedAt
}

model TaxaShopee {
  id                   String  @id @default(cuid())
  limInferiorCentavos  Int     @unique
  comissaoPct          Decimal @db.Decimal(5, 2)
  fixaCnpjCentavos     Int
  fixaCpfBaixoCentavos Int
  fixaCpfAltoCentavos  Int
}

model TaxaMercadoLivre {
  id                   String  @id @default(cuid())
  faixa                String  @unique // A..E
  limInferiorCentavos  Int
  custoFixoCentavos    Int
  pctAlternativo       Decimal @db.Decimal(5, 2)
  comissaoCategoriaPct Decimal @db.Decimal(5, 2)
}

/// Concorrente monitorado. Pode ser puramente manual (campos antigos: loja/instagram/website)
/// ou linkado a uma loja Shopee via shopId — nesse caso os campos shopee* são preenchidos
/// pelo último sync e o histórico de snapshots fica em ConcorrenteSnapshot.
model Concorrente {
  id                   String                @id @default(cuid())
  loja                 String
  instagram            String?
  website              String?
  observacao           String?
  // Campos opcionais quando a loja é Shopee (rastreio via API de afiliados).
  shopId               BigInt?               @unique
  username             String?
  urlOriginal          String?
  imageUrl             String?
  ratingStar           Decimal?              @db.Decimal(3, 2)
  commissionRatePadrao Decimal?              @db.Decimal(5, 4)
  sellerCommCoveRatio  Decimal?              @db.Decimal(5, 4)
  ultimoSyncEm         DateTime?
  precos               PrecoConcorrente[]
  snapshots            ConcorrenteSnapshot[]
  oportunidades        ProdutoOportunidade[]
  criadoEm             DateTime              @default(now())
  atualizadoEm         DateTime              @updatedAt
}

model PrecoConcorrente {
  id             String      @id @default(cuid())
  concorrenteId  String
  concorrente    Concorrente @relation(fields: [concorrenteId], references: [id], onDelete: Cascade)
  produtoSimilar String
  precoCentavos  Int
  capturadoEm    DateTime    @default(now())
  fonteUrl       String?
}

/// Snapshot de um sync da Shopee (manual ou cron). Cada execução cria uma nova linha
/// e os produtos retornados vão pra ConcorrenteSnapshotProduto vinculados a ela.
/// Sync com erro grava erroMensagem e qtdProdutos=0.
model ConcorrenteSnapshot {
  id             String                       @id @default(cuid())
  concorrenteId  String
  concorrente    Concorrente                  @relation(fields: [concorrenteId], references: [id], onDelete: Cascade)
  sincronizadoEm DateTime                     @default(now())
  origem         SyncOrigem
  qtdProdutos    Int                          @default(0)
  erroMensagem   String?
  produtos       ConcorrenteSnapshotProduto[]
  criadoEm       DateTime                     @default(now())

  @@index([concorrenteId, sincronizadoEm(sort: Desc)])
}

/// Produto retornado pela Shopee Affiliate naquele sync. Cópia imutável dos campos
/// expostos pela API (19 campos confirmados). Pra ver "estado atual" basta o último snapshot.
model ConcorrenteSnapshotProduto {
  id                 String                @id @default(cuid())
  snapshotId         String
  snapshot           ConcorrenteSnapshot   @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  itemId             BigInt
  productName        String
  priceMinCentavos   Int
  priceMaxCentavos   Int
  priceDiscountRate  Int
  /// `sales` cru da Shopee Affiliate API — período da campanha, NÃO histórico total.
  sales              Int
  /// Vendas totais reais (enriquecimento manual via Seller Center, opcional). Null = ainda não preenchido.
  vendasReais        Int?
  commissionRate     Decimal               @db.Decimal(5, 4)
  commissionCentavos Int
  imageUrl           String
  productLink        String
  offerLink          String
  productCatIds      Int[]
  shopType           Int[]
  ratingStar         Decimal?              @db.Decimal(3, 2)
  periodStartTime    DateTime
  periodEndTime      DateTime
  oportunidades      ProdutoOportunidade[]

  @@index([snapshotId, itemId])
}

/// Candidato a virar produto na Mahou. Materializado a partir de busca/varredura
/// em marketplaces (Shopee hoje; TikTok/ML no futuro via provider pattern).
/// Dedup por (marketplace, externalId) — mesma oportunidade é upsertada com dados frescos.
model ProdutoOportunidade {
  id String @id @default(cuid())

  marketplace OportunidadeMarketplace
  /// itemId Shopee, productId TikTok etc. String pra acomodar BigInt/UUID/etc.
  externalId  String

  productName        String
  priceMinCentavos   Int
  priceMaxCentavos   Int
  imageUrl           String
  productLink        String
  /// `sales` da Shopee Affiliate normalizado pra base mensal — NÃO histórico total. Antes inflava com 1/0.05; agora é só sales do afiliado projetado pra 30 dias.
  vendasAfiliadoMes  Int
  /// Vendas totais reais (enriquecimento manual via Seller Center, opcional). Null = ainda não preenchido.
  vendasReais        Int?
  ratingStar         Decimal? @db.Decimal(3, 2)
  /// IDs de categoria no marketplace (genérico — Shopee usa productCatIds).
  categoriaIds       Int[]
  lojaExternalId     String?
  lojaNome           String?

  fonte             OportunidadeFonte
  /// keyword, catId ou outro parâmetro que originou a oportunidade.
  fonteParam        String?
  concorrenteId     String?
  concorrente       Concorrente?                @relation(fields: [concorrenteId], references: [id], onDelete: SetNull)
  snapshotProdutoId String?
  snapshotProduto   ConcorrenteSnapshotProduto? @relation(fields: [snapshotProdutoId], references: [id], onDelete: SetNull)

  status    OportunidadeStatus @default(NOVO)
  /// 0..100, definido por Claude/manual após avaliação.
  score     Decimal?           @db.Decimal(5, 2)
  /// Análise livre (Claude preenche com justificativa estruturada).
  notas     String?
  produtoId String?            @unique
  produto   Produto?           @relation(fields: [produtoId], references: [id], onDelete: SetNull)

  criadoEm     DateTime          @default(now())
  atualizadoEm DateTime          @updatedAt
  logs         OportunidadeLog[]

  @@unique([marketplace, externalId])
  @@index([status, score(sort: Desc)])
  @@index([criadoEm(sort: Desc)])
}

enum OportunidadeLogAcao {
  CREATED
  STATUS_CHANGE
  SCORE_CHANGE
  NOTAS_CHANGE
  VIRARAM_PRODUTO
}

/// Audit trail das mudanças em ProdutoOportunidade. Append-only.
/// `detalhes` é JSON com payload da mudança (status: { de, para }, score: { de, para }, etc.).
/// `usuarioId` é null pra mudanças vindas do cron/sistema.
model OportunidadeLog {
  id             String              @id @default(cuid())
  oportunidadeId String
  oportunidade   ProdutoOportunidade @relation(fields: [oportunidadeId], references: [id], onDelete: Cascade)
  acao           OportunidadeLogAcao
  detalhes       Json
  usuarioId      String?
  criadoEm       DateTime            @default(now())

  @@index([oportunidadeId, criadoEm(sort: Desc)])
}

model JobProducao {
  id            String     @id @default(cuid())
  dataInicio    DateTime
  dataFim       DateTime?
  origem        Origem
  produtoId     String
  produto       Produto    @relation(fields: [produtoId], references: [id])
  qtd           Int
  prioridade    Int        @default(0)
  impressora    Impressora
  status        JobStatus  @default(FILA)
  anuncioCriado Boolean    @default(false)
  anunciado     Boolean    @default(false)
  observacao    String?
  criadoEm      DateTime   @default(now())
  atualizadoEm  DateTime   @updatedAt

  @@index([status])
  @@index([dataInicio])
}

