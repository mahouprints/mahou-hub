generator client {
  provider        = "prisma-client-js"
  previewFeatures = []
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Impressora {
  A1
  H2C
}

enum Canal {
  SHOPEE
  ML
  SITE
  TIKTOK
}

enum VendedorShopeeTipo {
  CNPJ
  CPF_BAIXO
  CPF_ALTO
}

enum Origem {
  ML
  SHOPEE
  SITE
  ESTOQUE
}

enum JobStatus {
  FILA
  IMPRIMINDO
  CONCLUIDO
  EMBALADO
  ENVIADO
  CANCELADO
}

enum OrigemImagem {
  INSPIRACAO
  MODELO_3D
  GERADA
  OUTRA
}

enum CategoriaCusto {
  ALUGUEL
  ENERGIA
  INTERNET
  SOFTWARE
  ASSINATURA
  MARKETING
  INSUMOS
  IMPOSTOS
  OUTROS
}

model Usuario {
  id        String   @id @default(cuid())
  email     String   @unique
  senhaHash String
  criadoEm  DateTime @default(now())
}

model Filamento {
  id              String    @id @default(cuid())
  nome            String    @unique
  custoKgCentavos Int
  potenciaA1W     Int
  potenciaH2cW    Int
  observacao      String?
  ativo           Boolean   @default(true)
  produtos        Produto[]
  criadoEm        DateTime  @default(now())
  atualizadoEm    DateTime  @updatedAt
}

model Produto {
  id                String          @id @default(cuid())
  nome              String
  inspiracao        String?
  modelo3dUrl       String?
  larguraCm         Decimal?        @db.Decimal(6, 1)
  alturaCm          Decimal?        @db.Decimal(6, 1)
  profundidadeCm    Decimal?        @db.Decimal(6, 1)
  filamentoId       String
  filamento         Filamento       @relation(fields: [filamentoId], references: [id])
  pesoG             Decimal         @db.Decimal(10, 2)
  tempoH            Decimal         @db.Decimal(10, 2)
  impressora        Impressora
  embalagemCentavos Int
  precoCentavos     Int
  canalPrincipal    Canal
  ativo             Boolean         @default(true)
  /// Indica se o produto já foi publicado no marketplace.
  /// Fluxo externo de geração de imagem só processa produtos com anunciado=false.
  anunciado         Boolean         @default(false)
  jobs              JobProducao[]
  vendas            Venda[]
  insumos           ProdutoInsumo[]
  imagens           ProdutoImagem[]
  criadoEm          DateTime        @default(now())
  atualizadoEm      DateTime        @updatedAt
}

/// Insumo reutilizável usado em vários produtos (caixa, fita, etiqueta).
/// Soft-delete via ativo=false — produtos antigos referenciam insumos antigos.
model Insumo {
  id                    String          @id @default(cuid())
  nome                  String          @unique
  unidade               String // texto livre: "un", "m", "kg", "ml"
  custoUnitarioCentavos Int
  observacao            String?
  ativo                 Boolean         @default(true)
  produtos              ProdutoInsumo[]
  criadoEm              DateTime        @default(now())
  atualizadoEm          DateTime        @updatedAt
}

/// Pivot Produto↔Insumo com quantidade consumida por unidade de produto.
/// qtd em Decimal(10,3) cobre frações: 0.5m de fita, 0.125kg de papel etc.
model ProdutoInsumo {
  id        String  @id @default(cuid())
  produtoId String
  produto   Produto @relation(fields: [produtoId], references: [id], onDelete: Cascade)
  insumoId  String
  insumo    Insumo  @relation(fields: [insumoId], references: [id])
  qtd       Decimal @db.Decimal(10, 3)

  @@unique([produtoId, insumoId])
}

/// Imagem de referência do produto (inspiração, modelo 3D, foto manual ou gerada).
/// `arquivo` é path relativo a STORAGE_DIR: "<produtoId>/<imagemId>.jpg".
/// Sharp normaliza tudo pra JPG max 2000px na hora do upload — original não fica.
model ProdutoImagem {
  id        String       @id @default(cuid())
  produtoId String
  produto   Produto      @relation(fields: [produtoId], references: [id], onDelete: Cascade)
  arquivo   String
  origem    OrigemImagem @default(OUTRA)
  ordem     Int          @default(0)
  larguraPx Int?
  alturaPx  Int?
  bytes     Int?
  criadoEm  DateTime     @default(now())

  @@index([produtoId])
}

model Venda {
  id                    String   @id @default(cuid())
  produtoId             String
  produto               Produto  @relation(fields: [produtoId], references: [id])
  qtd                   Int
  precoUnitarioCentavos Int      // pode diferir de Produto.precoCentavos
  canal                 Canal
  dataVenda             DateTime
  observacao            String?
  criadoEm              DateTime @default(now())

  @@index([dataVenda])
  @@index([canal])
}

/// Custo geral da Mahou Prints (aluguel, internet, software, etc).
/// `dataCompetencia` é sempre dia 1 do mês — agrupa por mês competência.
/// `recorrente=true` gera 12 cópias futuras na criação (com geradoAutomatico=true).
model Custo {
  id               String         @id @default(cuid())
  descricao        String
  categoria        CategoriaCusto
  valorCentavos    Int
  dataCompetencia  DateTime
  recorrente       Boolean        @default(false)
  geradoAutomatico Boolean        @default(false)
  observacao       String?
  criadoEm         DateTime       @default(now())

  @@index([dataCompetencia])
  @@index([categoria])
}

/// Singleton: sempre id=1. Configurações globais do Hub.
model Parametro {
  id                     Int                @id @default(1)
  tarifaKwhCentavos      Int
  vendedorShopee         VendedorShopeeTipo
  emCampanhaShopee       Boolean            @default(false)
  adicionalCampanhaPct   Decimal            @db.Decimal(5, 2)
  comissaoMlPct          Decimal            @db.Decimal(5, 2)
  impostoAtivo           Boolean            @default(false)
  impostoPct             Decimal            @db.Decimal(5, 2)
  // Taxas do TikTok Shop são percentuais simples (sem faixa por preço).
  // Defaults batem com a estrutura padrão (jul/2026): comissão+SFP+afiliado+pagamento.
  tiktokComissaoPlataformaPct Decimal       @default(6.00) @db.Decimal(5, 2)
  tiktokTaxaSfpPct            Decimal       @default(6.00) @db.Decimal(5, 2)
  tiktokComissaoAfiliadoPct   Decimal       @default(30.00) @db.Decimal(5, 2)
  tiktokTaxaPagamentoPct      Decimal       @default(3.00) @db.Decimal(5, 2)
  margemThresholdVerde   Decimal            @default(0.30) @db.Decimal(4, 3)
  margemThresholdAmarelo Decimal            @default(0.15) @db.Decimal(4, 3)
  atualizadoEm           DateTime           @updatedAt
}

model TaxaShopee {
  id                   String  @id @default(cuid())
  limInferiorCentavos  Int     @unique
  comissaoPct          Decimal @db.Decimal(5, 2)
  fixaCnpjCentavos     Int
  fixaCpfBaixoCentavos Int
  fixaCpfAltoCentavos  Int
}

model TaxaMercadoLivre {
  id                   String  @id @default(cuid())
  faixa                String  @unique // A..E
  limInferiorCentavos  Int
  custoFixoCentavos    Int
  pctAlternativo       Decimal @db.Decimal(5, 2)
  comissaoCategoriaPct Decimal @db.Decimal(5, 2)
}

model Concorrente {
  id         String             @id @default(cuid())
  loja       String
  instagram  String?
  website    String?
  observacao String?
  precos     PrecoConcorrente[]
  criadoEm   DateTime           @default(now())
}

model PrecoConcorrente {
  id             String      @id @default(cuid())
  concorrenteId  String
  concorrente    Concorrente @relation(fields: [concorrenteId], references: [id], onDelete: Cascade)
  produtoSimilar String
  precoCentavos  Int
  capturadoEm    DateTime    @default(now())
  fonteUrl       String?
}

model JobProducao {
  id            String     @id @default(cuid())
  dataInicio    DateTime
  dataFim       DateTime?
  origem        Origem
  produtoId     String
  produto       Produto    @relation(fields: [produtoId], references: [id])
  qtd           Int
  prioridade    Int        @default(0)
  impressora    Impressora
  status        JobStatus  @default(FILA)
  anuncioCriado Boolean    @default(false)
  anunciado     Boolean    @default(false)
  observacao    String?
  criadoEm      DateTime   @default(now())
  atualizadoEm  DateTime   @updatedAt

  @@index([status])
  @@index([dataInicio])
}
