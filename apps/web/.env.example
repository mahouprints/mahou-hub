# Usado pelo Next em dev (rewrite /api/* → API). Em prod a Vercel pode deixar
# vazio ou apontar pra qualquer coisa — o frontend ignora se NEXT_PUBLIC_API_BASE_URL
# estiver setado.
NEXT_PUBLIC_API_URL=http://localhost:3000
API_INTERNAL_URL=http://localhost:3000

# Em prod, defina pra `https://api.mahouprints.com` na Vercel. Faz o frontend
# chamar a API direto (sem proxy /api/*), evitando ROUTER_EXTERNAL_TARGET_CONNECTION_ERROR.
# Depende do cookie ser compartilhado em .mahouprints.com (COOKIE_DOMAIN na API).
# Em dev deixe vazio — cai no fallback /api/* (rewrite).
# NEXT_PUBLIC_API_BASE_URL=https://api.mahouprints.com
