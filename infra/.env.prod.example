POSTGRES_PASSWORD=<gerar com: openssl rand -base64 32>
JWT_SECRET=<gerar com: openssl rand -base64 32>
JWT_EXPIRES_IN=7d
CORS_ORIGIN=https://hub.mahouprints.com
ADMIN_EMAIL=mahouprints@gmail.com
ADMIN_INITIAL_PASSWORD=<gerar com: openssl rand -base64 16>
# Storage de imagens: STORAGE_HOST_DIR é o path da VPS, mapeado pra /app/storage no container.
# MEDIA_BASE_URL deve apontar pro subdomínio Nginx que serve esse diretório.
STORAGE_HOST_DIR=/var/mahou-storage
MEDIA_BASE_URL=https://media.mahouprints.com
